<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CYBER_INFO_COLLECTOR_V1.0</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&family=Noto+Sans+SC:wght@300;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --neon-green: #00ff9d;
            --dark-bg: #050505;
        }

        body {
            background-color: var(--dark-bg);
            color: var(--neon-green);
            font-family: 'Orbitron', 'Noto Sans SC', sans-serif;
            scroll-behavior: smooth;
        }

        /* CRT 扫描线特效 */
        body::before {
            content: " ";
            display: block;
            position: fixed;
            top: 0; left: 0; bottom: 0; right: 0;
            background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%), 
                        linear-gradient(90deg, rgba(255, 0, 0, 0.06), rgba(0, 255, 0, 0.02), rgba(0, 0, 255, 0.06));
            z-index: 100;
            background-size: 100% 4px, 3px 100%;
            pointer-events: none;
        }

        /* 赛博朋克切角容器 */
        .cyber-panel {
            clip-path: polygon(0% 0%, 95% 0%, 100% 5%, 100% 100%, 5% 100%, 0% 95%);
            border: 1px solid var(--neon-green);
            background: rgba(0, 255, 157, 0.03);
            box-shadow: inset 0 0 15px rgba(0, 255, 157, 0.1);
        }

        /* 霓虹输入框 */
        .cyber-input {
            background: rgba(0, 0, 0, 0.5);
            border: 1px solid rgba(0, 255, 157, 0.3);
            color: var(--neon-green);
            padding: 12px;
            transition: all 0.3s;
        }

        .cyber-input:focus {
            outline: none;
            border-color: var(--neon-green);
            box-shadow: 0 0 15px rgba(0, 255, 157, 0.5);
            background: rgba(0, 255, 157, 0.1);
        }

        /* 切角按钮 */
        .cyber-btn {
            background: var(--neon-green);
            color: black;
            font-weight: bold;
            clip-path: polygon(10% 0, 100% 0, 90% 100%, 0% 100%);
            transition: all 0.2s;
            cursor: pointer;
        }

        .cyber-btn:hover {
            transform: skewX(-5deg);
            box-shadow: -5px 0px 20px var(--neon-green);
            letter-spacing: 2px;
        }

        /* 装饰用的小方块 */
        .decoration-square {
            width: 8px;
            height: 8px;
            background: var(--neon-green);
            display: inline-block;
            margin-right: 5px;
        }

        section {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 20px;
        }

        ::-webkit-scrollbar { width: 5px; }
        ::-webkit-scrollbar-track { background: #050505; }
        ::-webkit-scrollbar-thumb { background: var(--neon-green); }
    </style>
</head>
<body>

    <div id="app">
        <nav class="fixed right-8 top-1/2 -translate-y-1/2 z-50 flex flex-col gap-4">
            <div v-for="i in 3" :key="i" class="w-3 h-3 border border-emerald-400 rotate-45"></div>
        </nav>

        <section id="identity">
            <div class="max-w-2xl w-full cyber-panel p-10">
                <div class="mb-8">
                    <h2 class="text-3xl font-bold uppercase tracking-tighter">
                        <span class="decoration-square"></span>身份认证 // IDENTITY
                    </h2>
                    <div class="h-1 w-full bg-emerald-900 mt-2">
                        <div class="h-full bg-emerald-400 w-1/3"></div>
                    </div>
                </div>

                <div class="space-y-6">
                    <div class="flex flex-col">
                        <label class="text-xs mb-2 opacity-70">代号 / CODENAME</label>
                        <input type="text" v-model="form.name" class="cyber-input" placeholder="输入你的赛博标签...">
                    </div>
                    <div class="flex flex-col">
                        <label class="text-xs mb-2 opacity-70">接入节点 / ACCESS_POINT</label>
                        <input type="email" v-model="form.email" class="cyber-input" placeholder="EMAIL_ADDRESS@NET.COM">
                    </div>
                </div>
                
                <div class="mt-12 text-right">
                    <p class="text-[10px] opacity-40 mb-2 italic text-left">>> 滚动以配置强化模组</p>
                    <button @click="scrollTo('specs')" class="px-8 py-2 cyber-btn">下一步</button>
                </div>
            </div>
        </section>

        <section id="specs">
            <div class="max-w-2xl w-full cyber-panel p-10 border-pink-500 shadow-[inset_0_0_15px_rgba(236,72,153,0.1)]">
                <style>.border-pink-500 { border-color: #ec4899 !important; }</style>
                <div class="mb-8">
                    <h2 class="text-3xl font-bold uppercase tracking-tighter text-pink-500">
                        <span class="decoration-square bg-pink-500"></span>技术规格 // SPECS
                    </h2>
                </div>

                <div class="grid grid-cols-2 gap-6">
                    <div v-for="skill in ['HACKING', 'REPAIR', 'COMBAT', 'STEALTH']" :key="skill" class="flex flex-col">
                        <label class="text-[10px] mb-2 text-pink-400">{{ skill }} LEVEL</label>
                        <input type="range" class="accent-pink-500 bg-zinc-900 h-1 cursor-pointer">
                    </div>
                </div>

                <div class="mt-10">
                    <label class="text-xs mb-2 block opacity-70">自我声明 / BIO_DATA</label>
                    <textarea v-model="form.bio" rows="4" class="w-full cyber-input border-pink-500 focus:shadow-[0_0_15px_rgba(236,72,153,0.5)]" placeholder="描述你的底层协议..."></textarea>
                </div>

                <div class="mt-8 flex justify-between">
                    <button @click="scrollTo('identity')" class="text-xs hover:text-white transition">返回上层</button>
                    <button @click="scrollTo('upload')" class="px-8 py-2 cyber-btn bg-pink-500">确认上传</button>
                </div>
            </div>
        </section>

        <section id="upload">
            <div class="text-center">
                <h1 class="text-6xl font-black mb-4 animate-pulse">SYSTEM_READY</h1>
                <p class="text-emerald-400 tracking-[0.5em] mb-10">数据包已封装，等待发送...</p>
                <div class="inline-block p-1 bg-emerald-400">
                    <button @click="submit" class="bg-black text-emerald-400 px-12 py-4 text-xl font-bold hover:bg-emerald-400 hover:text-black transition-all">
                        执行上传协议
                    </button>
                </div>
            </div>
        </section>
    </div>

    <script>
        const { createApp, ref } = Vue;

        createApp({
            setup() {
                const form = ref({
                    name: '',
                    email: '',
                    bio: ''
                });

                const scrollTo = (id) => {
                    document.getElementById(id).scrollIntoView({ behavior: 'smooth' });
                };

                const submit = () => {
                    alert(`[警告] 正在向骨干网上传数据...\n代号: ${form.value.name}\n状态: 成功`);
                };

                return { form, scrollTo, submit };
            }
        }).mount('#app');
    </script>
</body>
</html>
